# JACK AI Assistant - Environment Variables
# Most functionality works without these (using Ollama locally)

# Legacy OpenAI support (optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Legacy Perplexity support (optional)
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# WolframAlpha support (optional)
# WOLFRAM_ALPHA_APP_ID=your_wolfram_alpha_app_id_here

# Logging level
LOG_LEVEL=INFO

# --- HYPER-TITAN UPGRADE KEYS ---
# Unlock 100+ App Swarm: https://composio.dev
COMPOSIO_API_KEY=your_composio_api_key_here

# Upgrade Deep Research: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Ollama configuration (optional, defaults in config.py)
# OLLAMA_BASE_URL=http://localhost:11434
# ACTIVE_MODEL=llama3.2:1b
