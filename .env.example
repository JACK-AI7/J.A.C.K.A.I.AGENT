# Brain Settings (Premium APIs)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Voice Settings (ElevenLabs / OpenAI)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb  # George (JACK style) or your preference

# Email Ops (Required for email_ops skill)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Messaging (Selenium WhatsApp)
# No keys needed - manually scan QR code on first run

# Vision (Multimodal)
# Uses Gemini or local 'llava:latest' via Ollama

# Safety
OFFLINE_MODE=False  # Required for Cloud APIs
MASK_SENSITIVE_INFO=True

# FULLSTACK HIGHTECH (Advanced Sensors)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
E2B_API_KEY=your_e2b_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here # For Computer Use fallback
